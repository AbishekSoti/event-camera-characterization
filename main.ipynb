ffrom pathlib import Path
import numpy as np
import matplotlib.pyplot as plt
from faery.events_input import events_stream_from_file




# Remember, all files must be saved in the recordings directory that is at the same level as other codes and venv and external libraries.
# =========================
# USER SETTINGS
# =========================

RECORDINGS_DIR = Path.cwd() / "recordings"

FILE_NAME = "your_file.raw"   # change this
PATH = RECORDINGS_DIR / FILE_NAME

freq_hz = 50                  # example: 50 Hz. Set None if unknown.
period_us = None              # example: 20_000. Overrides freq_hz if given.

left_cut_us = 0               # remove this much from start
right_cut_us = 0              # remove this much from end

bins = 200
verbose = True

def load_events(path):
    path = Path(path)

    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")

    decoder = events_stream_from_file(str(path))
    events = decoder.to_array()

    if len(events) == 0:
        raise ValueError("No events loaded.")

    return events


def print_event_diagnostics(events):
    print("Event dtype:", events.dtype)
    print("Columns:", events.dtype.names)
    print("Number of events:", len(events))
    print("Bytes per event:", events.dtype.itemsize)

    t0 = events["t"][0]
    t1 = events["t"][-1]
    duration_s = (t1 - t0) / 1e6

    print(f"Start time: {t0} us")
    print(f"End time: {t1} us")
    print(f"Duration: {duration_s:.6f} s")
    print(f"Event rate: {len(events) / duration_s:,.0f} events/s")

    print("x range:", events["x"].min(), "to", events["x"].max())
    print("y range:", events["y"].min(), "to", events["y"].max())
    print("on values:", np.unique(events["on"]))


def trim_events(events, left_cut_us=0, right_cut_us=0):
    start_t = events["t"][0] + left_cut_us
    end_t = events["t"][-1] - right_cut_us

    if end_t <= start_t:
        raise ValueError("Trim cuts removed all data.")

    mask = (events["t"] >= start_t) & (events["t"] <= end_t)
    trimmed = events[mask]

    if len(trimmed) == 0:
        raise ValueError("No events after trimming.")

    return trimmed


def get_period_us(freq_hz=None, period_us=None):
    if period_us is not None:
        return int(period_us)

    if freq_hz is not None:
        return int(round(1e6 / freq_hz))

    raise ValueError("Provide either freq_hz or period_us for now.")


def find_clean_start(events, T, verbose=False):
    t = events["t"]
    p = events["on"]

    for i in range(2, len(p)):
        same_polarity = p[i] == p[i - 1] == p[i - 2]
        close_in_time = (t[i] - t[i - 2]) < (T // 2)

        if same_polarity and close_in_time:
            if verbose:
                print(f"Clean start: {t[i]} us, polarity={p[i]}")
            return t[i]

    if verbose:
        print("No clean start found. Using first timestamp.")

    return t[0]


def extract_full_cycles(events, T, verbose=False):
    t = events["t"]

    t0 = find_clean_start(events, T, verbose=verbose)
    t_end = t[-1]

    cycle_starts = np.arange(t0, t_end - T + 1, T, dtype=np.uint64)

    cycles = []

    for start in cycle_starts:
        end = start + T

        left = np.searchsorted(t, start, side="left")
        right = np.searchsorted(t, end, side="left")

        cycle = events[left:right]

        if len(cycle) > 0:
            cycles.append(cycle)

    if verbose:
        print(f"Extracted {len(cycles)} full cycles")

    return cycles


def fold_events(cycles, T):
    if len(cycles) == 0:
        raise ValueError("No cycles to fold.")

    folded_chunks = []

    for cycle in cycles:
        folded = cycle.copy()
        folded["t"] = (cycle["t"] - cycle["t"][0]) % T
        folded_chunks.append(folded)

    mega = np.concatenate(folded_chunks)
    mega.sort(order="t")

    return mega


def plot_mega_wave(mega_wave, T, bins=200):
    t = mega_wave["t"]
    on = mega_wave["on"]

    plt.figure(figsize=(11, 4))
    plt.hist(t[on], bins=bins, range=(0, T), alpha=0.6, label="ON events")
    plt.hist(t[~on], bins=bins, range=(0, T), alpha=0.6, label="OFF events")
    plt.title("Phase-Aligned Mega Wave")
    plt.xlabel("Time within cycle (µs)")
    plt.ylabel("Event count")
    plt.legend()
    plt.grid(True)
    plt.tight_layout()
    plt.show()


def plot_event_rate(events, bin_us=1000):
    t = events["t"]
    bins = np.arange(t[0], t[-1] + bin_us, bin_us)

    counts, edges = np.histogram(t, bins=bins)
    centers = (edges[:-1] + edges[1:]) / 2

    plt.figure(figsize=(11, 4))
    plt.plot((centers - t[0]) / 1e6, counts)
    plt.title(f"Event Count per {bin_us} µs Bin")
    plt.xlabel("Time (s)")
    plt.ylabel("Event count")
    plt.grid(True)
    plt.tight_layout()
    plt.show()


def analyse_event_file(
    path,
    freq_hz=None,
    period_us=None,
    left_cut_us=0,
    right_cut_us=0,
    bins=200,
    verbose=True,
):
    if verbose:
        print("[INFO] Loading events...")

    events = load_events(path)

    if verbose:
        print_event_diagnostics(events)

    if left_cut_us > 0 or right_cut_us > 0:
        if verbose:
            print(f"[INFO] Trimming left={left_cut_us} us, right={right_cut_us} us")

        events = trim_events(events, left_cut_us, right_cut_us)

        if verbose:
            print("[INFO] After trimming:")
            print_event_diagnostics(events)

    T = get_period_us(freq_hz=freq_hz, period_us=period_us)

    if verbose:
        used_freq = 1e6 / T
        print(f"[INFO] Period: {T} us")
        print(f"[INFO] Frequency: {used_freq:.6f} Hz")

    cycles = extract_full_cycles(events, T, verbose=verbose)
    mega_wave = fold_events(cycles, T)

    if verbose:
        print("[INFO] Folded event count:", len(mega_wave))

    plot_event_rate(events)
    plot_mega_wave(mega_wave, T, bins=bins)

    return events, cycles, mega_wave, T


## To run it:
events, cycles, mega_wave, T = analyse_event_file(
    PATH,
    freq_hz=freq_hz,
    period_us=period_us,
    left_cut_us=left_cut_us,
    right_cut_us=right_cut_us,
    bins=bins,
    verbose=verbose,
)


